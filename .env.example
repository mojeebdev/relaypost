# ──────────────────────────────────────────────────────────────
# Environment variable reference (placeholders only — no secrets)
# ──────────────────────────────────────────────────────────────
# On Lovable, these are managed automatically by Lovable Cloud
# and injected into the sandbox. This file exists only to document
# what the app reads at build/runtime.

# ── Client-side (inlined into browser bundle by Vite) ──
# Safe to expose — publishable / anon keys only.
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id_here
VITE_PENDO_API_KEY=your_pendo_api_key_here



# ── Server-side only (TanStack server functions / server routes) ──
# NEVER prefix these with VITE_ — that would leak them to the browser.
SUPABASE_URL=your_supabase_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # bypasses RLS — server only
LOVABLE_API_KEY=your_lovable_ai_gateway_key_here       # AI gateway — server only
